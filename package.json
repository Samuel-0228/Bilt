{
  "name": "bilt",
  "version": "1.0.0",
  "description": "Zero-configuration CLI toolkit that keeps local projects healthy before they reach Git.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "bilt": "./bin/bilt.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": ["cli", "security", "secrets", "env", "gitignore", "developer-tools"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "chokidar": "^4.0.3",
    "commander": "^15.0.0",
    "cosmiconfig": "^9.0.2",
    "dotenv": "^17.4.2",
    "enquirer": "^2.4.1",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "ora": "^9.4.1",
    "simple-git": "^3.27.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
